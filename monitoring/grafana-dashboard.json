{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "13.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "quote-api load test dashboard — request rate, CPU throttle ratio (latency proxy), replica count, CPU usage. Note: /metrics exposes only quote_requests_total (Counter); no latency histogram. CPU throttle ratio (cfs_throttled_periods/cfs_periods) is used as a latency-pressure proxy — it spikes when the pod's 500m CPU limit is saturating concurrent request threads.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(quote_requests_total{job=\"quote-api\"}[1m]))",
          "legendFormat": "req/s (all pods)",
          "refId": "A"
        }
      ],
      "title": "Request Rate (req/s)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(container_cpu_cfs_throttled_periods_total{container=\"quote-api\",namespace=\"quote-api\"}[1m])) / sum(rate(container_cpu_cfs_periods_total{container=\"quote-api\",namespace=\"quote-api\"}[1m]))",
          "legendFormat": "throttle ratio (all pods)",
          "refId": "A"
        }
      ],
      "title": "CPU Throttle Ratio — latency proxy (throttled_periods/total_periods)",
      "description": "App exposes no latency histogram. This ratio spikes when the 500m CPU limit throttles concurrent SHA-256 threads, extending per-request wall time. Baseline ~0%, peaks 10-14% under sustained 20-VU load (confirmed via cgroup cpu.stat).",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short",
          "decimals": 0,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 6 },
              { "color": "red", "value": 8 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "options": {
        "legend": { "calcs": ["max"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "kube_deployment_status_replicas{deployment=\"quote-api\",namespace=\"quote-api\"}",
          "legendFormat": "replicas (current)",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "kube_deployment_status_replicas_ready{deployment=\"quote-api\",namespace=\"quote-api\"}",
          "legendFormat": "replicas (ready)",
          "refId": "B"
        }
      ],
      "title": "Replica Count (HPA: min=3, max=8, target=70% CPU)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short",
          "decimals": 3
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "limit (500m × replicas)" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "dash": [4, 4], "fill": "dash" } },
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(container_cpu_usage_seconds_total{container=\"quote-api\",namespace=\"quote-api\"}[1m]))",
          "legendFormat": "CPU usage (cores, all pods)",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "kube_deployment_status_replicas{deployment=\"quote-api\",namespace=\"quote-api\"} * 0.5",
          "legendFormat": "limit (500m × replicas)",
          "refId": "B"
        }
      ],
      "title": "CPU Usage (cores) vs Limit",
      "description": "Aggregate CPU across all pods vs the theoretical limit (replicas × 500m). When usage approaches or exceeds the limit line, throttling increases.",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["quote-api", "load-test"],
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "quote-api Load Test",
  "uid": "quote-api-loadtest",
  "version": 1
}
